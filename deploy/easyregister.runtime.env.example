# EasyRegister runtime env example for GitHub Actions smoke/publish flows.
# A full runtime env can be supplied via the GitHub secret EASYREGISTER_RUNTIME_ENV_B64.
# Individual keys can also be overridden by secrets prefixed with EASYREGISTER_ENV_.

EASY_PROTOCOL_BASE_URL=http://easy-protocol:9788
EASY_PROTOCOL_CONTROL_TOKEN=
EASY_PROTOCOL_CONTROL_ACTOR=easyregister-gha
EASY_PROTOCOL_TIMEOUT_SECONDS=900

MAILBOX_SERVICE_BASE_URL=http://easy-email:8080
MAILBOX_SERVICE_API_KEY=

EASY_PROXY_BASE_URL=http://easy-proxy:29888
EASY_PROXY_API_KEY=

REGISTER_ENABLE_EASY_PROXY=true
REGISTER_REQUIRE_EASY_PROXY=true
REGISTER_PROXY_MODE=auto
REGISTER_PROXY_TTL_MINUTES=30
REGISTER_PROXY_UNIQUE_ATTEMPTS=3
REGISTER_PROXY_RECENT_WINDOW_SECONDS=180
REGISTER_PROXY_FAILURE_WINDOW_SECONDS=300

REGISTER_OUTPUT_ROOT=/shared/register-output/others/runs
REGISTER_INSTANCE_ID=easy-register
REGISTER_INSTANCE_ROLE=mixed
REGISTER_FLOW_PATH=
REGISTER_FLOW_SPECS_JSON=
# REGISTER_FLOW_SPECS_JSON=[{"name":"openai-main","path":"server/services/orchestration_service/flows/codex-openai-account-v1.semantic-flow.json","role":"main","weight":5},{"name":"openai-continue","path":"server/services/orchestration_service/flows/codex-openai-oauth-continue-v1.semantic-flow.json","role":"continue","weight":2},{"name":"codex-team-expand","path":"server/services/orchestration_service/flows/codex-team-expand-v1.semantic-flow.json","role":"team","weight":1}]
REGISTER_TEAM_AUTH_PATH=
REGISTER_TEAM_AUTH_PATHS=
REGISTER_TEAM_AUTH_GLOB=*-team.json
REGISTER_TEAM_AUTH_LOCAL_DIR=
REGISTER_TEAM_AUTH_DEFAULT_DIR=
REGISTER_TEAM_AUTH_DIR=

REGISTER_DASHBOARD_ENABLED=false
REGISTER_LOOP_DELAY_SECONDS=30
REGISTER_WORKER_COUNT=10
REGISTER_MAIN_CONCURRENCY_LIMIT=5
REGISTER_CONTINUE_CONCURRENCY_LIMIT=2
REGISTER_TEAM_CONCURRENCY_LIMIT=1
REGISTER_WORKER_STAGGER_SECONDS=1
REGISTER_INFINITE_MAX_RUNS=0
REGISTER_TASK_MAX_ATTEMPTS=0

REGISTER_OPENAI_OAUTH_POOL_DIR=
REGISTER_OPENAI_OAUTH_SUCCESS_POOL_DIR=
REGISTER_OPENAI_OAUTH_WAIT_POOL_DIR=
REGISTER_OPENAI_OAUTH_CONTINUE_POOL_DIR=
REGISTER_OPENAI_OAUTH_WAIT_SECONDS=
REGISTER_OPENAI_OAUTH_CONTINUE_PREFILL_COUNT=
REGISTER_OPENAI_OAUTH_CONTINUE_PREFILL_TARGET_COUNT=
REGISTER_OPENAI_OAUTH_CONTINUE_PREFILL_MIN_AGE_SECONDS=
REGISTER_OPENAI_OAUTH_SEED_MAX_AGE_SECONDS=900
REGISTER_OPENAI_UPLOAD_PERCENT=0
REGISTER_CODEX_FREE_UPLOAD_PERCENT=0
REGISTER_CODEX_TEAM_UPLOAD_PERCENT=0
REGISTER_CODEX_PLUS_UPLOAD_PERCENT=0

REGISTER_MAILBOX_ROUTING_PROFILE_ID=
REGISTER_MAILBOX_STRATEGY_MODE_ID=
REGISTER_MAILBOX_PROVIDERS=
REGISTER_MAILBOX_BUSINESS_KEY=generic
REGISTER_MAILBOX_DOMAIN_POOL=cnmlgb.de,zhooo.org,zhooo.ggff.net,coolkidsa.ggff.net,shaole.me,cpu.edu.kg,tmail.bio,do4.tech
REGISTER_MAILBOX_DOMAIN_BLACKLIST=coolkid.icu,shaole.me,cpu.edu.kg,tmail.bio,do4.tech
REGISTER_MAILBOX_BUSINESS_POLICIES_JSON={"default":{"domainPool":["cnmlgb.de","zhooo.org","zhooo.ggff.net","coolkidsa.ggff.net","shaole.me","cpu.edu.kg","tmail.bio","do4.tech"],"explicitBlacklistDomains":["coolkid.icu","shaole.me","cpu.edu.kg","tmail.bio","do4.tech"]},"openai":{"domainPool":["cnmlgb.de","zhooo.org","zhooo.ggff.net","coolkidsa.ggff.net","shaole.me","cpu.edu.kg","tmail.bio","do4.tech"],"explicitBlacklistDomains":["coolkid.icu","shaole.me","cpu.edu.kg","tmail.bio","do4.tech"]}}

# Compose-side host output aliases are configured outside this runtime env file.
# Use scripts/deploy-compose.ps1 plus these host env vars when you need directory links:
# REGISTER_OUTPUT_DIR_HOST
# REGISTER_OUTPUT_ALIAS_ROOT_HOST
# REGISTER_OPENAI_PENDING_DIR_HOST
# REGISTER_OPENAI_CONVERTED_DIR_HOST
# REGISTER_OPENAI_FAILED_ONCE_DIR_HOST
# REGISTER_OPENAI_FAILED_TWICE_DIR_HOST
# REGISTER_CODEX_FREE_DIR_HOST
# REGISTER_CODEX_TEAM_DIR_HOST
# REGISTER_CODEX_PLUS_DIR_HOST
# REGISTER_CODEX_TEAM_INPUT_DIR_HOST
# REGISTER_CODEX_TEAM_MOTHER_INPUT_DIR_HOST
# Current local defaults live in deploy-host.ps1.
